---
import { getCollection } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: index > 0
        ? { slug: posts[index - 1].slug, title: posts[index - 1].data.title }
        : undefined,
      nextPost: index < posts.length - 1
        ? { slug: posts[index + 1].slug, title: posts[index + 1].data.title }
        : undefined,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<Post post={post} readingTime={readingTime} prevPost={prevPost} nextPost={nextPost}>
  <Content />
</Post>
